<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, user-scalable=no" />
  <meta name="theme-color" content="#000000" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Пятница" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <title>Пятница v0.2.2</title>
  <link rel="manifest" href="./manifest.json" />
  <link rel="apple-touch-icon" href="./icons/icon-192.png" />
  <link rel="stylesheet" href="./style.css" />
</head>
<body>
  <main id="stage" aria-label="Пятница v0.2.2">
    <section id="face" class="face idle">
      <div class="eyes-wrap" id="eyesWrap">
        <div class="eye left-eye" data-eye="left">
          <div class="glow"></div>
          <div class="lid top"></div>
          <div class="lid bottom"></div>
          <div class="listen-ring"></div>
        </div>
        <div class="eye right-eye" data-eye="right">
          <div class="glow"></div>
          <div class="lid top"></div>
          <div class="lid bottom"></div>
          <div class="listen-ring"></div>
        </div>
      </div>
    </section>

    <aside id="menu" class="menu hidden" aria-hidden="true">
      <div class="menu-card" id="menuCard" role="dialog" aria-label="Меню Пятницы">
        <div class="menu-title">Пятница v0.2.2</div>
        <div class="menu-subtitle">Голос + разблокировка звука</div>

        <button type="button" data-action="listen">Слушать команду</button>
        <button type="button" data-action="voice-test">Тест голоса</button>
        <button type="button" data-action="wake">Внимание</button>
        <button type="button" data-action="idle">Обычный режим</button>
        <button type="button" data-action="quiet">Тихий режим</button>
        <button type="button" data-action="sleep">Спать</button>
        <button type="button" data-action="tuesday">Preview Вторника</button>
        <button type="button" data-action="about">О прототипе</button>

        <div class="menu-divider"></div>

        <button type="button" data-action="close">Закрыть</button>
      </div>
    </aside>


    <aside id="voiceGate" class="voice-gate">
      <div class="voice-gate-card">
        <div class="voice-gate-title">Голос Пятницы</div>
        <div class="voice-gate-text">Нажми один раз, чтобы включить голос на iPhone.</div>
        <button type="button" id="unlockVoiceBtn">Включить голос</button>
        <button type="button" id="skipVoiceBtn">Пока без голоса</button>
      </div>
    </aside>

    <aside id="toast" class="toast hidden" aria-live="polite"></aside>
  </main>

  <script src="./app.js"></script>
</body>
</html>
